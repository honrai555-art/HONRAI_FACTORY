# Discord Developer Portal で取得
# https://discord.com/developers/applications

# --- 共通 ---
# Bot タブ → Reset Token で取得（他人に見せない）
DISCORD_TOKEN=your_bot_token_here

# --- Python 工場 Bot（factory_bot.py）---
# コマンドを受け付けるチャンネル ID（空なら全チャンネル）
ALLOWED_CHANNEL_ID=

# プロジェクトルート（未設定時は HONRAI_FACTORY ルート）
PROJECT_ROOT=

# git pull 対象ディレクトリ（未設定時は PROJECT_ROOT）
GIT_PULL_DIR=

# Unity / 漫画 / ComfyUI 連携（使う機能だけ設定）
UNITY_EXE=
UNITY_PROJECT_PATH=
DISCORD_WEBHOOK_URL=

# PowerShell 実行ファイル（通常は変更不要）
POWERSHELL_EXE=powershell

# --- discord.js 学習用（src/）---
# General Information → Application ID
DISCORD_CLIENT_ID=your_application_client_id_here

# 開発用サーバー ID（右クリック → ID をコピー、開発者モード要）
# テスト中は guild 登録を使うと反映が速い（数秒）
DISCORD_GUILD_ID=your_test_server_id_here
